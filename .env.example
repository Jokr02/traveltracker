# Postgres-Connection-String (lokal: Ausgabe von `npx prisma dev`, produktiv: Vercel Postgres/Neon)
DATABASE_URL="postgresql://user:password@localhost:5432/traveltracker"

# Passwort für den Single-User-Login
APP_PASSWORD="changeme"

# Zufälliger Secret-String zum Signieren der Session-Cookies, z.B. via: openssl rand -base64 32
SESSION_SECRET=""

# Optional: aktiviert Foto-Upload bei Besuchen (siehe README → Foto-Upload)
BLOB_READ_WRITE_TOKEN=""

# Optional: zweite, isolierte Postgres-DB für den Demo-Modus (siehe README → Demo-Modus).
# Wenn nicht gesetzt, ist der "Demo ausprobieren"-Button auf /login unsichtbar.
DEMO_DATABASE_URL=""
