// Prisma schema — Travel Tracker
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Nur relevant, solange ein Land noch keinen Visit hat — der erste Visit
// macht ein Land automatisch "besucht", unabhängig vom PlanningStatus.
enum PlanningStatus {
  NONE
  WISHLIST
  PLANNED
}

enum TransportMode {
  PLANE
  CAR
  TRAIN
  BUS
  FERRY
  OTHER
}

model Country {
  id             String         @id @default(cuid())
  cca3           String         @unique
  ccn3           String?
  name           String
  continent      String
  subregion      String?
  latitude       Float
  longitude      Float
  areaKm2        Float?
  flagEmoji      String?
  borders        String[]
  languages      String[]
  currencies     String[]
  planningStatus PlanningStatus @default(NONE)

  visits           Visit[]
  homeForSettings  Setting[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([continent])
}

model Trip {
  id        String   @id @default(cuid())
  name      String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  visits Visit[]
}

model Visit {
  id             String          @id @default(cuid())
  countryId      String
  country        Country         @relation(fields: [countryId], references: [id], onDelete: Cascade)
  tripId         String?
  trip           Trip?           @relation(fields: [tripId], references: [id], onDelete: SetNull)
  startDate      DateTime
  endDate        DateTime?
  notes          String?
  rating         Int?
  coverImageUrl  String?
  transportModes TransportMode[]

  photos VisitPhoto[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([countryId])
  @@index([tripId])
}

model VisitPhoto {
  id        String   @id @default(cuid())
  visitId   String
  visit     Visit    @relation(fields: [visitId], references: [id], onDelete: Cascade)
  url       String
  createdAt DateTime @default(now())

  @@index([visitId])
}

// Singleton-Tabelle (eine Zeile, id = "singleton") für App-weite Einstellungen
// eines Single-User-Setups.
model Setting {
  id            String   @id @default("singleton")
  homeCountryId String?
  homeCountry   Country? @relation(fields: [homeCountryId], references: [id], onDelete: SetNull)
  updatedAt     DateTime @updatedAt
}
