// Prisma schema — Travel Tracker
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Nur relevant, solange ein Land noch keinen Visit hat — der erste Visit
// macht ein Land automatisch "besucht", unabhängig vom PlanningStatus.
enum PlanningStatus {
  NONE
  WISHLIST
  PLANNED
}

enum TransportMode {
  PLANE
  CAR
  TRAIN
  BUS
  FERRY
  OTHER
}

model Country {
  id             String         @id @default(cuid())
  cca3           String         @unique
  cca2           String?        @unique
  ccn3           String?
  name           String
  continent      String
  subregion      String?
  latitude       Float
  longitude      Float
  areaKm2        Float?
  flagEmoji      String?
  borders        String[]
  languages      String[]
  currencies     String[]
  planningStatus PlanningStatus @default(NONE)

  visits           Visit[]
  homeForSettings  Setting[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([continent])
}

model Trip {
  id         String   @id @default(cuid())
  name       String
  notes      String?
  // Für Importer (z.B. Polarsteps): externe Trip-ID, verhindert Doppel-Import.
  externalId String?  @unique
  // Tatsächlicher GPS-Track als [lng, lat]-Punktliste (z.B. aus Polarsteps
  // locations.json), für die Kartendarstellung. Ohne Import: null, dann wird
  // eine gerade Linie zwischen den Länder-Mittelpunkten gezeichnet.
  route      Json?
  // Tatsächlich gefahrene/geflogene Distanz (z.B. Polarsteps' total_km).
  // Fehlt sie, wird auf der Reisen-Seite die Luftlinie zwischen den
  // Stationen als Schätzung angezeigt.
  distanceKm Float?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  visits Visit[]
}

model Visit {
  id             String          @id @default(cuid())
  countryId      String
  country        Country         @relation(fields: [countryId], references: [id], onDelete: Cascade)
  tripId         String?
  trip           Trip?           @relation(fields: [tripId], references: [id], onDelete: SetNull)
  startDate      DateTime
  endDate        DateTime?
  notes          String?
  rating         Int?
  coverImageUrl  String?
  transportModes TransportMode[]

  photos VisitPhoto[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([countryId])
  @@index([tripId])
}

model VisitPhoto {
  id        String   @id @default(cuid())
  visitId   String
  visit     Visit    @relation(fields: [visitId], references: [id], onDelete: Cascade)
  // Pfad im (privaten) Vercel-Blob-Store, kein direkt aufrufbarer öffentlicher
  // Link — Auslieferung läuft über /api/photos/[...path], siehe dort.
  pathname  String
  createdAt DateTime @default(now())

  @@index([visitId])
}

// Singleton-Tabelle (eine Zeile, id = "singleton") für App-weite Einstellungen
// eines Single-User-Setups.
model Setting {
  id            String   @id @default("singleton")
  homeCountryId String?
  homeCountry   Country? @relation(fields: [homeCountryId], references: [id], onDelete: SetNull)
  updatedAt     DateTime @updatedAt
}

// Fehlgeschlagene Login-Versuche pro IP, für simples Rate-Limiting.
// Alte Einträge werden opportunistisch beim Login gelöscht (kein Cronjob nötig).
model LoginAttempt {
  id        String   @id @default(cuid())
  ip        String
  createdAt DateTime @default(now())

  @@index([ip, createdAt])
}

// Steuert den periodischen Reset der Demo-Daten (siehe src/lib/demo/reset.ts).
// Existiert per Schema auch in der echten DB, wird dort aber nie verwendet —
// nur die Demo-DB (DEMO_DATABASE_URL) hat eine befüllte Zeile.
model DemoState {
  id          String   @id @default("singleton")
  lastResetAt DateTime @default(now())
}
